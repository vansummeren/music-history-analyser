# ─────────────────────────────────────────────────────────────────────────────
# Core
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_DB=musicanalyser
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql+asyncpg://postgres:change-me-in-production@db:5432/musicanalyser

# ─────────────────────────────────────────────────────────────────────────────
# Redis / Celery
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────────────────────────────────────
# CORS — comma-separated list of allowed origins
# ─────────────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Authentication — choose "oidc" or "saml"
# See docs/idp-configuration.md for full setup instructions for each IdP.
# ─────────────────────────────────────────────────────────────────────────────
AUTH_PROVIDER=oidc

# OIDC settings (required when AUTH_PROVIDER=oidc)
OIDC_DISCOVERY_URL=https://your-idp.example.com/.well-known/openid-configuration
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
# REQUIRED in production — the exact redirect URI you registered with your IdP.
# Must point to <public-backend-url>/api/auth/oidc/callback.
# When left blank the backend auto-detects the URI from the incoming request,
# which only works correctly in local development (no reverse proxy).
OIDC_REDIRECT_URI=https://your-app.example.com/api/auth/oidc/callback
# Claim name in the userinfo / ID-token that carries the user's roles list.
# Defaults to "roles".  Set to "groups" for Authentik / Okta.
OIDC_ROLES_CLAIM=roles

# ── Authentik (OIDC) example ─────────────────────────────────────────────────
# OIDC_DISCOVERY_URL=https://<authentik-host>/application/o/<app-slug>/.well-known/openid-configuration
# OIDC_CLIENT_ID=<client-id>
# OIDC_CLIENT_SECRET=<client-secret>
# OIDC_ROLES_CLAIM=groups

# SAML settings (required when AUTH_PROVIDER=saml)
SAML_IDP_METADATA_URL=https://your-idp.example.com/metadata.xml
SAML_SP_ENTITY_ID=https://your-app.example.com
SAML_SP_ACS_URL=https://your-app.example.com/api/auth/saml/acs
# Attribute name in the SAML assertion that carries the user's roles list.
# Defaults to "roles".  Set to "groups" for Authentik.
SAML_ROLES_ATTRIBUTE=roles

# ── Authentik (SAML) example ──────────────────────────────────────────────────
# SAML_IDP_METADATA_URL=https://<authentik-host>/api/v3/providers/saml/<id>/metadata/?download
# SAML_SP_ENTITY_ID=https://your-app.example.com
# SAML_SP_ACS_URL=https://your-app.example.com/api/auth/saml/acs
# SAML_ROLES_ATTRIBUTE=groups

# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────

# Public URL of the frontend — used to build post-authentication redirect URLs.
# REQUIRED in production.  Set to the full URL users access the app with.
FRONTEND_URL=https://your-app.example.com

# ─────────────────────────────────────────────────────────────────────────────
# Spotify
# ─────────────────────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/spotify/callback

# ─────────────────────────────────────────────────────────────────────────────
# SMTP
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com
SMTP_TLS=true
